# ─── MONEI MCP Server Configuration ──────────────────────────
# Copy this file to .env and fill in your values.
# Only MONEI_API_KEY is required for development.

# ─── Server ──────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── MONEI GraphQL API ───────────────────────────────────────
# Required: Your MONEI API key from Dashboard → Settings → API Access
# https://dashboard.monei.com/settings/api
MONEI_API_KEY=

# Optional: Override the GraphQL endpoint (default: https://graphql.monei.com)
# MONEI_GRAPHQL_ENDPOINT=https://graphql.monei.com

# ─── OAuth 2.0 (production only) ────────────────────────────
# These are needed for the merchant OAuth flow.
# Leave empty for local development with API key auth.
# MONEI_CLIENT_ID=
# MONEI_CLIENT_SECRET=
# MONEI_REDIRECT_URI=http://localhost:3000/oauth/callback
