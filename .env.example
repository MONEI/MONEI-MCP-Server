# MONEI MCP Server Configuration
# ================================

# Server
PORT=3000
HOST=0.0.0.0

# MONEI OAuth Application Credentials
# Register at: https://dashboard.monei.com/settings/developers
MONEI_CLIENT_ID=your_client_id
MONEI_CLIENT_SECRET=your_client_secret

# OAuth callback URL (must match your registered redirect URI)
MONEI_REDIRECT_URI=http://localhost:3000/oauth/callback

# MONEI API
MONEI_API_BASE_URL=https://api.monei.com/v1

# Logging
LOG_LEVEL=info
